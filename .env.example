# -----------------------------
# Agent Identity
# -----------------------------
APP_NAME=Agent 1
ENVIRONMENT=dev
TIMEZONE=America/Jamaica

# Optional OpenClaw-style home layout root.
# Defaults to ~/.agent1.
# Windows example: ${USERPROFILE}/.agent1
# Linux/macOS example: ${HOME}/.agent1
AGENT1_HOME_PATH=~/.agent1
AGENT1_HOME_SCAFFOLD_ENABLED=false

# -----------------------------
# LLM (OpenAI-Compatible)
# -----------------------------
# Provider used by default when a user has not selected one:
LLM_DEFAULT_PROVIDER=custom

# Custom profile (direct fast API mode, no proxy/gateway):
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-4o

# Built-in provider profiles (users can switch with /provider):
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

XAI_BASE_URL=https://api.x.ai/v1
XAI_API_KEY=
XAI_MODEL=grok-3-latest

# Anthropic compatibility endpoint (if you expose one):
ANTHROPIC_COMPAT_BASE_URL=
ANTHROPIC_COMPAT_API_KEY=
ANTHROPIC_COMPAT_MODEL=claude-3-5-sonnet-latest

# Ollama local profile:
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=llama3.1:8b-instruct

LLM_TEMPERATURE=0.2
LLM_TIMEOUT_SECONDS=45
LLM_MAX_TOKENS=1800

# Shadow Gateway migration path:
# Later, only change these values:
# LLM_BASE_URL=https://your-shadow-gateway/v1
# LLM_API_KEY=your_shadow_gateway_key

# -----------------------------
# Telegram
# -----------------------------
# Adapter mode: telegram | discord | slack | whatsapp | bridge | cli
CHAT_ADAPTER=telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
# Optional fallback destination for proactive messages
TELEGRAM_DEFAULT_CHAT_ID=

# Discord adapter
DISCORD_BOT_TOKEN=
DISCORD_ALLOWED_USER_IDS=

# Slack adapter (Socket Mode)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_ALLOWED_USER_IDS=

# WhatsApp Cloud API adapter (webhook + send API)
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ALLOWED_PHONE_NUMBERS=
WHATSAPP_HOST=0.0.0.0
WHATSAPP_PORT=8790
WHATSAPP_API_VERSION=v21.0

# Generic webhook bridge for WhatsApp/iMessage-style connectors
BRIDGE_HOST=0.0.0.0
BRIDGE_PORT=8787
BRIDGE_AUTH_TOKEN=
BRIDGE_ALLOWED_CHANNELS=whatsapp,imessage,custom

# -----------------------------
# Storage / Runtime
# -----------------------------
DATA_DIR=./data
SAFE_FILES_ROOT=./data/safe_workspace
SAFE_SHELL_WORKDIR=./data/safe_workspace
SAFE_SHELL_ALLOWED_COMMANDS=ls,pwd,echo,cat,rg,python,python3,pip,git,pytest
SAFE_SHELL_TIMEOUT_SECONDS=20
AUTO_APPROVE_RISKY_ACTIONS=false
DEFAULT_TOOL_PROFILE=full
TOOL_POLICY_GLOBAL_ALLOW=
TOOL_POLICY_GLOBAL_DENY=
TOOL_POLICY_GLOBAL_DENY_PERMISSIONS=

MARKDOWN_MEMORY_PATH=./data/memory
VECTOR_MEMORY_PATH=./data/chroma
APPROVAL_STORE_PATH=./data/approvals/pending.json
SUBSCRIBERS_STORE_PATH=./data/approvals/subscribers.json
PROVIDER_PREFERENCES_PATH=./data/approvals/provider_preferences.json
TOOL_POLICY_STORE_PATH=./data/approvals/tool_policy.json
APP_LOG_PATH=./data/logs/app.log
TOOL_LOG_PATH=./data/logs/tool_calls.log
AGENTGUARD_AUDIT_LOG_PATH=./data/logs/agentguard_audit.log
USAGE_METER_PATH=./data/logs/usage_meter.jsonl
WORKSPACE_PROFILE_PATH=./workspace
SKILLS_ROOT_PATH=./workspace/skills
SKILLS_REGISTRY_PATH=./workspace/skills/registry.json
SKILL_EXEC_TIMEOUT_SECONDS=45
SKILL_USE_VENV_IF_PRESENT=true
# auto = read per-skill Runtime from SKILL.md when present
SKILL_RUNTIME_MODE=auto
SKILL_DOCKER_IMAGE=python:3.11-slim
SKILL_DOCKER_MEMORY_MB=512
SKILL_DOCKER_CPUS=1.0
SKILL_BLOCK_UNSAFE_ARGS=true
PLUGINS_ROOT_PATH=./workspace/plugins
PLUGINS_REGISTRY_PATH=./workspace/plugins/registry.json
PLUGIN_GIT_TIMEOUT_SECONDS=120

# External approvals daemon bridge (OpenClaw-style)
EXTERNAL_APPROVALS_ENABLED=false
# Portable example: ${USERPROFILE}/.openclaw/exec-approvals.json (Windows)
# Portable example: ${HOME}/.openclaw/exec-approvals.json (Linux/macOS)
# Portable Agent 1 example: ${USERPROFILE}/.agent1/exec-approvals.json
# Portable Agent 1 example: ${HOME}/.agent1/exec-approvals.json
# Windows note: approvals config supports TCP fallback (host/port) when AF_UNIX is unavailable.
EXTERNAL_APPROVALS_CONFIG_PATH=
EXTERNAL_APPROVALS_TIMEOUT_SECONDS=2

SESSION_MAX_CONCURRENCY=2
SESSION_JOBS_PATH=./data/sessions/jobs.json
SESSION_HISTORY_PATH=./data/sessions/history.jsonl
SESSION_MAX_HISTORY_PER_USER=200
SCHEMA_STATE_PATH=./data/schema_state.json

# -----------------------------
# Proactive Scheduler
# -----------------------------
PROACTIVE_MODE_ENABLED=true
MORNING_BRIEFING_HOUR=8
MORNING_BRIEFING_MINUTE=0
PENDING_TASK_DIGEST_HOURS=6

# -----------------------------
# Search / Browser
# -----------------------------
MAX_SEARCH_RESULTS=5
BROWSER_MAX_CHARS=5000
WEB_USER_AGENT=Agent1/0.1 (+local-self-hosted)

# -----------------------------
# Email (Gmail/Outlook via IMAP + SMTP)
# -----------------------------
EMAIL_ENABLED=false
EMAIL_ADDRESS=
EMAIL_PASSWORD=
EMAIL_IMAP_HOST=imap.gmail.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USE_STARTTLS=true
EMAIL_MAILBOX=INBOX

# -----------------------------
# Google Calendar
# -----------------------------
CALENDAR_ENABLED=false
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_CREDENTIALS_PATH=./data/google_credentials.json
GOOGLE_CALENDAR_TOKEN_PATH=./data/google_token.json
